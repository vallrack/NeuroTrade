
{
  "entities": {
    "UserProfile": {
      "title": "Perfil de Usuario",
      "description": "Almacena información básica de los operadores y administradores de la plataforma.",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["operator", "admin", "super-admin"] },
        "lastActive": { "type": "string", "format": "date-time" }
      },
      "required": ["email"]
    },
    "BrokerConfig": {
      "title": "Configuración del Bróker",
      "description": "Credenciales y estado de conexión con el bróker (ej. IQ Option).",
      "type": "object",
      "properties": {
        "provider": { "type": "string" },
        "email": { "type": "string" },
        "password": { "type": "string" },
        "accountType": { "type": "string", "enum": ["demo", "real"] },
        "status": { "type": "string", "enum": ["connected", "pending", "disconnected"] },
        "connectedAt": { "type": "string", "format": "date-time" }
      }
    },
    "BotParams": {
      "title": "Parámetros del Bot",
      "description": "Configuración operativa avanzada para el bot de trading de IA (Versión 7).",
      "type": "object",
      "properties": {
        "investmentPerTrade": { "type": "number" },
        "stopLoss": { "type": "number" },
        "takeProfit": { "type": "number" },
        "maxLosses": { "type": "number", "description": "Límite de pérdidas consecutivas." },
        "minRsi": { "type": "number", "description": "Umbral inferior de RSI para sobreventa." },
        "maxRsi": { "type": "number", "description": "Umbral superior de RSI para sobrecompra." },
        "martingale": { "type": "boolean" },
        "pairs": { "type": "array", "items": { "type": "string" } },
        "schedules": { 
          "type": "array", 
          "items": { 
            "type": "object",
            "properties": {
              "start": { "type": "string" },
              "end": { "type": "string" }
            }
          }
        },
        "bot_activo": { "type": "boolean" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Trade": {
      "title": "Operación de Trading",
      "description": "Registro de una operación ejecutada por el bot.",
      "type": "object",
      "properties": {
        "pair": { "type": "string" },
        "direction": { "type": "string", "enum": ["CALL", "PUT"] },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["win", "loss", "pending"] },
        "timestamp": { "type": "string", "format": "date-time" },
        "profit": { "type": "number" },
        "accountType": { "type": "string" }
      }
    },
    "DailyEquity": {
      "title": "Rendimiento Diario",
      "description": "Registro de seguimiento de rendimiento diario.",
      "type": "object",
      "properties": {
        "date": { "type": "string", "format": "date" },
        "equity": { "type": "number" }
      }
    },
    "DashboardStats": {
      "title": "Estadísticas del Dashboard",
      "description": "Resumen de las estadísticas actuales de trading.",
      "type": "object",
      "properties": {
        "balance": { "type": "number" },
        "dailyProfit": { "type": "number" },
        "winRate": { "type": "number" },
        "totalInvestment": { "type": "number" }
      }
    }
  },
  "auth": {
    "providers": ["email"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Datos del perfil de usuario."
    },
    "/users/{userId}/config/broker": {
      "schema": "BrokerConfig",
      "description": "Configuración privada del bróker para cada usuario."
    },
    "/users/{userId}/trades/{tradeId}": {
      "schema": "Trade",
      "description": "Historial de operaciones del usuario."
    },
    "/configuracion/bot_params": {
      "schema": "BotParams",
      "description": "Configuración global de los parámetros del bot."
    },
    "/rendimiento_diario/{recordId}": {
      "schema": "DailyEquity",
      "description": "Datos temporales para el gráfico de equidad."
    },
    "/dashboard/current_stats": {
      "schema": "DashboardStats",
      "description": "Resumen de estadísticas en tiempo real."
    }
  }
}
