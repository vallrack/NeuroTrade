
{
  "entities": {
    "UserProfile": {
      "title": "Perfil de Usuario",
      "description": "Almacena información básica de los operadores y administradores de la plataforma.",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["operator", "admin", "super-admin"] },
        "lastActive": { "type": "string", "format": "date-time" }
      },
      "required": ["email"]
    },
    "BrokerConfig": {
      "title": "Configuración del Bróker",
      "description": "Credenciales y estado de conexión con múltiples brókeres.",
      "type": "object",
      "properties": {
        "provider": { "type": "string", "enum": ["IQ Option", "Alpaca", "Binance", "Bybit"] },
        "email": { "type": "string" },
        "password": { "type": "string" },
        "apiKey": { "type": "string" },
        "apiSecret": { "type": "string" },
        "accountType": { "type": "string", "enum": ["demo", "real"] },
        "status": { "type": "string", "enum": ["connected", "pending", "disconnected"] },
        "connectedAt": { "type": "string", "format": "date-time" }
      }
    },
    "BotParams": {
      "title": "Parámetros del Bot",
      "description": "Configuración operativa avanzada para el bot de trading de IA (Versión 7).",
      "type": "object",
      "properties": {
        "investmentPerTrade": { "type": "number" },
        "stopLoss": { "type": "number" },
        "takeProfit": { "type": "number" },
        "minBalance": { "type": "number" },
        "maxLosses": { "type": "number" },
        "maxTradesPerDay": { "type": "number" },
        "minRsi": { "type": "number" },
        "midRsi": { "type": "number" },
        "maxRsi": { "type": "number" },
        "martingale": { "boolean": "boolean" },
        "pairs": { "type": "array", "items": { "type": "string" } },
        "schedules": { 
          "type": "array", 
          "items": { 
            "type": "object",
            "properties": {
              "start": { "type": "string" },
              "end": { "type": "string" }
            }
          }
        },
        "bot_activo": { "type": "boolean" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Trade": {
      "title": "Operación de Trading",
      "description": "Registro de una operación ejecutada por el bot.",
      "type": "object",
      "properties": {
        "pair": { "type": "string" },
        "direction": { "type": "string", "enum": ["CALL", "PUT"] },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["win", "loss", "pending"] },
        "timestamp": { "type": "string", "format": "date-time" },
        "profit": { "type": "number" },
        "accountType": { "type": "string" },
        "broker": { "type": "string" }
      }
    },
    "MarketTick": {
      "title": "Tick de Mercado (RTDB)",
      "description": "Precio en tiempo real inyectado por el bot de Python.",
      "type": "object",
      "properties": {
        "price": { "type": "number" },
        "timestamp": { "type": "number" },
        "rsi": { "type": "number" }
      }
    }
  },
  "auth": {
    "providers": ["email"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Datos del perfil de usuario."
    },
    "/users/{userId}/config/broker": {
      "schema": "BrokerConfig",
      "description": "Configuración privada del bróker para cada usuario."
    },
    "/users/{userId}/trades/{tradeId}": {
      "schema": "Trade",
      "description": "Historial de operaciones del usuario."
    },
    "/configuracion/bot_params": {
      "schema": "BotParams",
      "description": "Configuración global de los parámetros del bot."
    }
  }
}
