
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ── FUNCIONES HELPER ────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      // Intenta obtener el rol, pero devuelve falso si hay error (evita fallos circulares)
      return isSignedIn() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'super-admin'];
    }

    // ── USUARIOS ─────────────────────────────────────────────────
    match /users/{userId} {
      // El dueño o el admin pueden leer y ver el perfil
      allow read: if isOwner(userId) || isAdmin();
      
      // Permitir creación inicial si está logueado
      allow create: if isSignedIn() && request.auth.uid == userId;

      // El dueño puede actualizar cosas no críticas. Admin puede todo.
      allow update: if isOwner(userId) || isAdmin();

      // Sub-colecciones de usuario (trades, config, analytics, etc)
      match /{allSubcollections=**} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    // ── LOGS DEL SISTEMA ────────────────────────────────────────
    match /logs/{logId} {
      // Todos los operadores deben poder ver los logs
      allow read: if isSignedIn();
      // Solo el sistema/admin puede escribir (o el usuario si el log es sobre él)
      allow write: if isSignedIn();
    }

    // ── CONFIGURACIÓN GLOBAL ────────────────────────────────────
    match /configuracion/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /rendimiento_diario/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ── REGLA DE EMERGENCIA ─────────────────────────────────────
    // Permitir lectura de cualquier documento si el usuario es super-admin
    match /{path=**} {
      allow read: if isAdmin();
    }
  }
}
