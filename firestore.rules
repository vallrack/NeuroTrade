
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ── FUNCIONES HELPER ────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getRole() {
      // Usamos el operador de seguridad para evitar errores si el documento no existe aún
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isSignedIn() && (getRole() == 'admin' || getRole() == 'super-admin');
    }

    // ── USUARIOS ─────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      
      // Permitir creación inicial de perfil si el usuario está autenticado
      allow create: if isSignedIn() && request.auth.uid == userId;

      allow update: if isOwner(userId) && (
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'disabled'])
      ) || isAdmin();

      // Sub-colecciones
      match /{allSubcollections=**} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    // ── CONFIGURACIÓN GLOBAL ────────────────────────────────────
    match /configuracion/{docId} {
      // CUALQUIER OPERADOR debe poder leer los parámetros para que el bot funcione
      allow read: if isSignedIn();
      // SOLO ADMINS pueden modificar la estrategia
      allow write: if isAdmin();
    }

    match /rendimiento_diario/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /dashboard/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
