
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Perfil de usuario y configuraciones
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Permitir acceso a subcolecciones de configuración y estadísticas
      match /config/{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      
      match /trading_stats/{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /trades/{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Configuración global del bot
    match /configuracion/bot_params {
      allow read: if request.auth != null;
      allow write: if request.auth != null; // En producción, restringir a admins
    }

    // Logs para la terminal
    match /logs/{logId} {
      allow read, write: if request.auth != null;
    }
  }
}
